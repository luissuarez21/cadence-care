# Cadence — environment template (CAD-9)
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored and must
# NEVER be committed. This template documents every secret the backend reads.
#
#   cp .env.example .env
#
# Stack: Anthropic · Redis · Arize · Web Push. (No Poke/Sentry keys needed.)

# ── Anthropic (LLM orchestrator + Claude Vision plan ingest) ─────────────────
# Model used everywhere is claude-sonnet-4-6 (do not hardcode older versions).
ANTHROPIC_API_KEY=

# ── Redis (per-patient memory, symptom logs, risk timeline, RAG vectors) ─────
# Use rediss:// for TLS (required by the contract). Plaintext redis:// for local dev only.
REDIS_URL=rediss://<host>:<port>
REDIS_PASSWORD=

# ── Arize (agent decision tracing + LLM-as-judge eval) ───────────────────────
ARIZE_API_KEY=
ARIZE_SPACE_ID=

# ── Web Push / VAPID (zero-PHI escalation notifications to clinician browser) ─
# Generate a keypair with:  python -m backend.notifications.push --generate-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:team@cadence.health

# ── CORS (optional; defaults to the Vite dev origin http://localhost:5173) ───
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
